{
  "name": "codex-gemini-web-bridge",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "check": "for file in scripts/*.mjs; do node --check \"$file\"; done && node --check dist/mcp-server.mjs && node --check dist/gemini-web-cli.mjs",
    "cli": "node dist/gemini-web-cli.mjs",
    "pretest": "npm run build",
    "test": "node --test tests/*.test.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "esbuild": "0.28.1"
  }
}
